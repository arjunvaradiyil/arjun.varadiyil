# Set to true to show maintenance screen on home (no nav links or CTAs)
MAINTENANCE_MODE=false

# Resend (contact form)
RESEND_API_KEY=

# Payload CMS (site works without these — uses static data in src/data/)
PAYLOAD_SECRET=your-long-random-secret-here
DATABASE_URI=mongodb://127.0.0.1:27017/portfolio
# Set to false to skip CMS on the frontend (static fallback only)
# CMS_ENABLED=false

# Site URL — MUST match how you open the site (admin + media URLs)
# Local dev:
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
# Production (Vercel/hosting env vars — not in committed .env):
# NEXT_PUBLIC_SERVER_URL=https://arjunvaradiyil.in

# Optional extra Payload admin origins (comma-separated)
# PAYLOAD_CORS_ORIGINS=https://preview.example.com

# AWS S3 (Payload Media uploads)
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional folder prefix inside the bucket
AWS_S3_PREFIX=portfolio/media
#
# Required on the S3 bucket for admin uploads (CORS → Allowed origins):
#   http://localhost:3000
#   https://arjunvaradiyil.in
# Allowed methods: GET, PUT, HEAD. Allowed headers: *

# Optional: first admin (only used by seed:create-admin)
# PAYLOAD_ADMIN_EMAIL=you@example.com
# PAYLOAD_ADMIN_PASSWORD=
